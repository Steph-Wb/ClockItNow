# ── JWT ─────────────────────────────────────────────────────────────────────
# Zufälliger geheimer Schlüssel (mindestens 32 Zeichen)
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ersetze-mich-mit-einem-langen-zufaelligen-string

# ── SMTP (E-Mail-Versand für Magic Links) ────────────────────────────────────
# Gmail: 2FA aktivieren → Google-Konto → Sicherheit → App-Passwörter → generieren
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=deine@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=ClockItNow <deine@gmail.com>

# ── App-URL ──────────────────────────────────────────────────────────────────
# Wird für Magic-Link-URLs im E-Mail verwendet
# Lokal: http://localhost:5173
# Produktion: https://deine-domain.com
APP_URL=http://localhost:5173
