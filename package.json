{
  "name": "clockitnow",
  "version": "1.0.0",
  "description": "Self-hosted, local-first time tracking app — an open-source Clockify alternative with client/project management and monthly Excel work report (timesheet) export",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Steph-Wb/ClockItNow.git"
  },
  "bugs": {
    "url": "https://github.com/Steph-Wb/ClockItNow/issues"
  },
  "homepage": "https://github.com/Steph-Wb/ClockItNow#readme",
  "keywords": [
    "time-tracking",
    "timesheet",
    "self-hosted",
    "clockify-alternative",
    "work-report",
    "invoicing",
    "freelancer",
    "sqlite",
    "react",
    "express"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "tsx watch server/index.ts",
    "client": "vite",
    "build": "tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "i18next": "^26.3.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.395.0",
    "nodemailer": "^8.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
